---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import classnames from 'classnames';

interface Props {
  idx: number;
  title: string;
  description: string;
  styles: string,
  imgPath: string;
  classNames?: string | string[];
  onDark?: boolean;
}

const { idx, title, description, styles, imgPath, classNames, onDark } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/services/*.png'
);
---

<section
  class={classnames(
    'col-span-6 rounded-2xl p-12 flex flex-col gap-7', styles,
    classNames,
    {
      'text-[#ffff]': onDark,
      'text-[#3C3843]': !onDark,
    }
  )}
>
  <span class='font-medium text-[28px] leading-8'>{`{${idx}}`}</span>
  <h3 class='font-medium text-[28px] leading-8'>{title}</h3>
  <p class='text-base leading-7'>{description}</p>
  {images[imgPath] && <Image src={images[imgPath]()} alt='lalala' />}
</section>
