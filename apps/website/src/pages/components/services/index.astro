---
import services from '../../../assets/content/services.json'
import ServiceCard from '../ServiceCard.astro';
const styles = [
  "bg-orange-500",
  "bg-blue-500",
  "bg-orange-500"
]
---


<section class='grid grid-cols-6 gap-3 px-3'>
  {
    services.map((value, idx) => (
      <ServiceCard
        idx={idx + 1}
        title={value.title}
        description={value.description}
        styles={styles[idx]}
        classNames={value.styles}
        onDark={idx === 1}
        imgPath={value.imgPath}
      />
    ))
  }
</section>
