---
const styles = [
  'bg-[#5362DBE5] translate-y-0',
  'bg-[#424C6DE5] top-[calc(140px-100vh)] translate-y-0',
  'bg-[#3C3843E5] top-[calc(280px-200vh)] translate-y-0',
  'bg-[#1E1A1AE5] top-[calc(440px-300vh)] translate-y-0',
];
---

<div id='services' class="w-full">
  <div
    class='h-screen overflow-hidden sticky top-0 max-w-[1440px] mx-auto'
  >
    <div
      id='first'
      data-show='true'
      class='bg-yellow-500 w-full [&[data-show="true"]]:opacity-100 transition-opacity duration-300 absolute top-[calc(100vh-560px)] ease-in-out opacity-0 rounded-2xl h-screen'
    >
    </div>
    <div
      data-show='true'
      class='bg-purple-500 w-full [&[data-show="true"]]:opacity-100 transition-opacity duration-300 absolute top-[calc(100vh-560px+140px)] ease-in-out opacity-0 rounded-2xl h-screen'
    >
    </div>
    <div
      data-show='true'
      class='bg-orange-500 w-full [&[data-show="true"]]:opacity-100 transition-opacity duration-300 absolute top-[calc(100vh-560px+140px+140px)] ease-in-out opacity-0 rounded-2xl h-screen'
    >
    </div>
    <div
      data-show='true'
      class='bg-fuchsia-500 w-full [&[data-show="true"]]:opacity-100 transition-opacity duration-300 absolute top-[calc(100vh-560px+140px+140px+140px)] ease-in-out opacity-0 rounded-2xl h-screen'
    >
    </div>
    <!-- {
      services.map((value, idx) => (
        <ServiceCard
          idx={idx + 1}
          title={value.title}
          description={value.description}
          styles={styles[idx]}
          onDark={idx === 1}
          imgPath={value.imgPath}
        />
      ))
    } -->
  </div>
</div>
<script is:inline>
  console.log("HELLO")
  const servicesWrapper = document.getElementById('services');
  const allHiddenElems = document.querySelectorAll('[data-show]');
  const screenHeight = window.innerHeight;

  const r = {};
  let wrapperHeight = 4 * 140;

  allHiddenElems.forEach((el, idx) => {
    if (idx === 0) {
      r[idx] = {
        distanceFromTop: screenHeight - 4 * 140,
        top: 0,
      };
    } else {
      const prev = r[idx - 1];
      r[idx] = {
        distanceFromTop: prev.distanceFromTop + 140,
        top: prev.distanceFromTop + prev.top,
      };
    }
    wrapperHeight += r[idx].top;
  });

  servicesWrapper.style.height = `${wrapperHeight}px`;

  let lastScrollTopPos = 0;

  window.addEventListener('scroll', () => {
    const currentScrollTop = window.scrollY;
    const servicesWrapperBoundingRect = servicesWrapper.getBoundingClientRect();

    if (
      servicesWrapperBoundingRect.top <= 0 &&
      lastScrollTopPos < currentScrollTop
    ) {
      const fromTop = servicesWrapperBoundingRect.top * -1;
      allHiddenElems.forEach((elem, idx) => {
        const elemBoundingRect = elem.getBoundingClientRect();

        const isPrevOnTop =
          idx === 0 || allHiddenElems[idx - 1].getBoundingClientRect().top <= 0;
        if (isPrevOnTop && elemBoundingRect.top > 0) {
          console.log(`translateY(-${fromTop - r[idx].top}px)`, idx);
          elem.style.transform = `translateY(-${fromTop - r[idx].top}px)`;
        }
      });
    }

   /*  if (
      servicesWrapperBoundingRect.bottom >= screenHeight &&
      lastScrollTopPos > currentScrollTop
    ) {
      console.log('Going up and in view');
    } */
    lastScrollTopPos = currentScrollTop <= 0 ? 0 : currentScrollTop;
  });
</script>
