---
import * as formContent from "../content/contact/get-your-plan-form.md";
import "../styles/loader.css";
import Field from "./Field.astro";
import GetYourPlanModal from "./GetYourPlanModal.astro";
---

<div class="col-span-6 lg:col-span-5 lg:col-start-2 md:row-start-2">
  <form
    id="get-your-plan-form"
    class="group/contact-us mx-auto flex-col gap-2"
    novalidate
  >
    <Field
      isTextArea={false}
      onDark
      inputProps={{
        name: "form-full-name",
        maxlength: "100",
        placeholder: formContent.frontmatter.fullname,
        required: true,
        minlength: 2,
      }}
      labelProps={{
        for: "form-full-name",
        "aria-hidden": "false",
      }}
      label={formContent.frontmatter.fullname}
      errorText={formContent.frontmatter.fullnameLength}
    />
    <Field
      isTextArea={false}
      onDark
      inputProps={{
        name: "form-email",
        maxlength: "100",
        placeholder: formContent.frontmatter.email,
        type: "email",
        required: true,
      }}
      labelProps={{
        for: "form-email",
        "aria-hidden": "false",
      }}
      label={formContent.frontmatter.email}
      errorText={formContent.frontmatter.emailInvalid}
    />
    <div>
      <div class="flex gap-2.5 py-4">
        <input
          id="form-consent"
          name="form-consent"
          type="checkbox"
          required
          aria-describedby="form-consent-text"
          class="h-4 w-4 rounded border-gray-300 text-[#67a807] focus:ring-[#67a807] mt-1 cursor-pointer"
        />
        <label
          set:html={formContent.frontmatter.consent}
          id="form-consent-text"
          for="form-consent"
          class="text-neutral-50 [&>em]:not-italic [&_b]:text-[#67a807] [&>em]:font-semibold cursor-pointer"
        />
      </div>
      <button
        type="submit"
        id="form-submit-button"
        class="rounded-md
        min-h-14
        px-[25px] w-full py-4
        text-center
        text-secondary
        text-base
        font-medium
        group-invalid/contact-us:pointer-events-none
        group-invalid/contact-us:opacity-30
        group-invalid/contact-us:focus-visible:bg-[#85a32a]
        group-invalid/contact-us:focus-visible:outline-transparent
        group-invalid/contact-us:focus:bg-[#85a32a]
        bg-crocoder-yellow
        hover:bg-crocoder-yellow/90
        focus:bg-crocoder-yellow/90
        focus-visible:bg-crocoder-yellow/90
        focus-visible:outline-1
        focus-visible:outline-neutral-50"
      >
        <span class="flex gap-3 items-center justify-center"
          >{formContent.frontmatter.submit}
          <svg
            width="16"
            height="17"
            viewBox="0 0 16 17"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M1.04395 8.50154H14.9767M14.9767 8.50154L9.14396 1.56421M14.9767 8.50154L9.14396 15.4776"
              stroke="black"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
        <div class="loader mx-auto hidden"></div>
      </button>
      <button id="open-get-plan-modal" type="button"> Open modal </button>
      <GetYourPlanModal />
      <p id="form-notification" class="text-sm min-h-6 pt-1"></p>
    </div>
    <script>
      import * as notification from "../content/contact/notification.md";

      const form = document.getElementById("get-your-plan-form");

      const submitBtn = form?.querySelector("#form-submit-button");
      const submitBtnElems = submitBtn?.querySelectorAll("*");
      const submitBtnContent = submitBtnElems && submitBtnElems[0];
      const submitBtnLoader = submitBtnElems && submitBtnElems[1];

      const openGetPlanModalBtn = document.getElementById(
        "open-get-plan-modal",
      );
      const getPlanModal = document.getElementById(
        "get-plan-modal",
      ) as HTMLDialogElement | null;

      getPlanModal?.showModal();
      const notificationElem = form?.querySelector("#form-notification");

      const showLoader = () => {
        if (submitBtnContent && submitBtnLoader) {
          submitBtnContent.classList.add("hidden");
          submitBtnLoader.classList.add("!block");
        }
      };

      const hideLoader = () => {
        if (submitBtnContent && submitBtnLoader) {
          submitBtnContent.classList.remove("hidden");
          submitBtnLoader.classList.remove("!block");
        }
      };

      const handleModalSoftDismiss = (e: PointerEvent) => {
        if (!e.currentTarget) return;

        const dialogTarget = e.currentTarget as HTMLDialogElement;

        if (e.target === dialogTarget) {
          dialogTarget.close();
        }
      };

      const handleOpenModal = () => {
        if (getPlanModal) {
          getPlanModal.showModal();
        }
      };

      if (openGetPlanModalBtn && getPlanModal) {
        openGetPlanModalBtn.addEventListener("click", handleOpenModal);
        getPlanModal.addEventListener("click", handleModalSoftDismiss);
      }

      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const formData = new FormData(e.target as HTMLFormElement);
          const name = formData.get("form-full-name");
          const email = formData.get("form-email");
          const consent = formData.get("form-consent");

          if (!name || !email || !consent) {
            return;
          }

          showLoader();
          const response = await fetch("/api/get-plan", {
            method: "POST",
            mode: "cors",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              name,
              email,
              hasConsent: consent ? true : false,
            }),
          });

          if (response.status !== 200 && notificationElem) {
            notificationElem.classList.add("text-red-500");
            notificationElem.textContent = notification.frontmatter.error;
            hideLoader();
            return;
          }

          // Redirect to success page
          window.location.href = "/contact/success";
        });
      }
    </script>
  </form>
</div>
