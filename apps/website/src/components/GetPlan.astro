---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import sectionImage from "../assets/crocodile-board.png";
import Field from "./Field.astro";
import * as formContent from "../content/contact/consult-us-form.md";
import "../styles/loader.css";
import { grid_classes } from "./_grid";
---

<Section className="!py-0 !px-0">
  <div class={`${grid_classes}bg-[#4E5BC8] items-start p-7 lg:!gap-y-7 py-16`}>
    <div
      class="col-span-6 max-w-[500px] md:col-start-7 md:row-start-2 lg:row-start-1 lg:row-span-2"
    >
      <Image
        src={sectionImage}
        alt="Illustration of crocodile presenting analytics on a board"
        widths={[320, 480, 640, 800, 1196]}
        sizes="(max-width: 540px) calc(67vw - 21px), (max-width: 768px) calc(67vw - 21px), (max-width: 1280px) calc(58vw - 32px), calc(50vw - 28px)"
      />
    </div>
    <div
      class="col-span-6 flex flex-wrap gap-7 items-center md:col-span-12 lg:row-start-1 lg:col-span-5 lg:col-start-2"
    >
      <svg
        width="103"
        height="103"
        viewBox="0 0 103 103"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M95.7741 55.0237C95.0997 63.5 92.0065 71.6046 86.8612 78.3745C81.716 85.1446 74.7362 90.2952 66.7496 93.2143C58.7635 96.134 50.107 96.6997 41.8088 94.8446C33.5106 92.9888 25.9194 88.7906 19.9371 82.7476C13.9548 76.7052 9.83285 69.072 8.06096 60.7556C6.28906 52.4391 6.9417 43.7888 9.94135 35.8324C12.941 27.876 18.1616 20.9479 24.9829 15.8711C31.8041 10.7944 39.9393 7.78242 48.422 7.19312"
          stroke="white"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M70.564 58.9476C69.3301 62.1236 67.324 64.9418 64.7271 67.1476C62.1303 69.3533 59.0246 70.877 55.6908 71.5808C52.3571 72.2844 48.9005 72.1464 45.6337 71.1785C42.3669 70.2106 39.3928 68.4437 36.9804 66.0376C34.5681 63.6314 32.7935 60.6619 31.8173 57.3975C30.841 54.1332 30.6938 50.677 31.389 47.3415C32.0842 44.0059 33.5999 40.8963 35.799 38.2937C37.998 35.6912 40.8111 33.6779 43.9838 32.4358"
          stroke="white"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M51.5002 51.5008L68.5826 34.4185"
          stroke="#FEB534"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M82.2484 37.8342L68.5825 34.4177L65.166 20.7518L78.8319 7.08594L82.2484 20.7518L95.9143 24.1683L82.2484 37.8342Z"
          stroke="#FEB534"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <h3
        class="font-medium text-4xl text-white max-w-[500px] lg:max-w-[362px] tracking-[-0.7px]"
      >
        Your <span class="text-crocoder-yellow">Free Development Plan</span> in Less
        Than 24 Hours!
      </h3>
    </div>
    <div class="col-span-6 md:col-span-5 md:col-start-2 md:row-start-2">
      <form class="group/contact-us mx-auto flex-col gap-2" novalidate>
        <Field
          isTextArea={false}
          onDark
          inputProps={{
            name: "form-full-name",
            maxlength: "100",
            placeholder: formContent.frontmatter.fullname,
            required: true,
            minlength: 3,
          }}
          labelProps={{
            for: "form-full-name",
            "aria-hidden": "false",
          }}
          label={formContent.frontmatter.fullname}
          errorText={formContent.frontmatter.fullnameLength}
        />
        <Field
          isTextArea={false}
          onDark
          inputProps={{
            name: "form-email",
            maxlength: "100",
            placeholder: formContent.frontmatter.email,
            type: "email",
            required: true,
          }}
          labelProps={{
            for: "form-email",
            "aria-hidden": "false",
          }}
          label={formContent.frontmatter.email}
          errorText={formContent.frontmatter.emailInvalid}
        />
        <div>
          <button
            id="form-submit-button"
            class="rounded-md
            min-h-14
            group-invalid/contact-us:focus-visible:bg-[#85a32a]
            group-invalid/contact-us:focus-visible:outline-transparent
            group-invalid/contact-us:focus:bg-[#85a32a]
            bg-crocoder-yellow
            hover:bg-[#84a22ab3]
            px-[25px] w-full py-4
            focus-visible:bg-[#84a22ab3]
            focus:bg-[#84a22ab3]
            focus-visible:outline-1
            focus-visible:outline-secondary
            text-center
            text-secondary
            text-base
            font-medium mt-6"
          >
            <span class="flex gap-3 items-center justify-center"
              >{formContent.frontmatter.submit}
              <svg
                width="16"
                height="17"
                viewBox="0 0 16 17"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M1.04395 8.50154H14.9767M14.9767 8.50154L9.14396 1.56421M14.9767 8.50154L9.14396 15.4776"
                  stroke="black"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
            <div class="loader mx-auto hidden"></div>
          </button>
          <p id="form-notification" class="text-sm min-h-6 pt-1"></p>
        </div>
      </form>
    </div>
  </div>
</Section>
